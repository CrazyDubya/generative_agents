[flake8]
max-line-length = 88
extend-ignore = 
    E203,  # whitespace before ':'
    E501,  # line too long (handled by black)
    W503,  # line break before binary operator
exclude = 
    .git,
    __pycache__,
    .venv,
    venv,
    env,
    ENV,
    .env,
    migrations,
    settings,
    build,
    dist,
    .tox,
    *.egg-info
max-complexity = 10
per-file-ignores =
    __init__.py:F401
    settings/*.py:E402
    */migrations/*.py:E501